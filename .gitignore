# BrainVault — Project Root
# This gitignore covers both backend and frontend

# ── Python / Backend ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Backend env (contains secrets)
backend/.env
!backend/.env.example

# ── Node / Frontend ─────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ── IDE / Editor ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Logs ────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ──────────────────────────────────────────────────────────────
Thumbs.db
